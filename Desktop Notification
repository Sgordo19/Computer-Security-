#!/usr/bin/env python3
"""
alert.py
Displays desktop alerts via notify-send and stores alert history in alerts.log.
Falls back to console output if notify-send is unavailable.
"""

import subprocess
from datetime import datetime

ALERT_FILE = "alerts.log"


# ─── Internal helpers ─────────────────────────────────────────────────────────

def _send_popup(title: str, message: str) -> None:
    """Attempt to show a desktop notification via notify-send."""
    try:
        subprocess.run(
            ["notify-send", title, message, "-u", "critical"],
            check=True,
            capture_output=True,
        )
        print(f"[ALERT] Popup sent → {title}")
    except (FileNotFoundError, subprocess.CalledProcessError):
        # notify-send not available (headless server, CI, etc.) — fall back to console
        print(f"[ALERT] {title} :: {message}")


def _write_alert(message: str) -> None:
    """Append a timestamped alert message to alerts.log."""
    timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    with open(ALERT_FILE, "a") as fh:
        fh.write(f"[{timestamp}] {message}\n")


# ─── Public API ───────────────────────────────────────────────────────────────

def send_alert(message: str) -> None:
    """
    Main function called by hids.py.

    Classifies the alert, sends a desktop popup, and writes to alerts.log.
    """
    if not message:
        return

    msg_lower = message.lower()

    if "brute" in msg_lower or "ssh" in msg_lower:
        title = "HIDS Alert: SSH Attack"
    elif "modified" in msg_lower:
        title = "HIDS Alert: File Modified"
    elif "deleted" in msg_lower:
        title = "HIDS Alert: File Deleted"
    elif "new file" in msg_lower:
        title = "HIDS Alert: New File Detected"
    else:
        title = "HIDS Alert"

    _send_popup(title, message)
    _write_alert(message)


# ─── Standalone test ──────────────────────────────────────────────────────────

if __name__ == "__main__":
    send_alert("SSH BRUTE FORCE DETECTED: 192.168.1.100 (5 attempts, users: root, admin)")
    send_alert("FILE WAS MODIFIED: /etc/passwd  (old: f4b3114b…  new: 9ca8db79…)")
    send_alert("NEW FILE FOUND: /var/www/html/shell.php")
    send_alert("FILE WAS DELETED: /etc/hosts  (last hash: 85e4edeb…)")
    print(f"\n[ALERT] Check '{ALERT_FILE}' for persisted alert history.")
