#!/usr/bin/env python3

"""
alert.py - Simple alert handler for HIDS
Displays desktop alerts and stores alert history.
"""

import subprocess
from datetime import datetime

ALERT_FILE = "alerts.log"


def _send_popup(title, message):
    """Attempt to show a desktop notification."""
    try:
        subprocess.run(
            ["notify-send", title, message, "-u", "critical"],
            check=True
        )
        print(f"[ALERT] Popup sent -> {title}")
    except Exception:
        print(f"[ALERT] {title} :: {message}")


def _write_alert(message):
    """Save alert message to alerts.log."""
    timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")

    with open(ALERT_FILE, "a") as f:
        f.write(f"[{timestamp}] {message}\n")


def send_alert(message):
    """
    Main function used by HIDS.
    Determines alert type and handles notification + logging.
    """
    if not message:
        return

    msg = message.lower()

    if "brute" in msg or "ssh" in msg:
        title = "HIDS Alert: SSH Attack"
    elif "modified" in msg or "deleted" in msg:
        title = "HIDS Alert: File Change"
    elif "new" in msg:
        title = "HIDS Alert: New File"
    else:
        title = "HIDS Alert"

    _send_popup(title, message)
    _write_alert(message)
