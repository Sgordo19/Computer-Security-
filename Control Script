#!/usr/bin/env python3
"""
hids.py — Host-Based Intrusion Detection System (Control Script)
Orchestrates file integrity monitoring, SSH brute-force detection,
centralized logging, and desktop/file alerting.

Usage:
    python hids.py               # continuous loop (Ctrl-C to stop)
    python hids.py --once        # run a single detection cycle and exit
    python hids.py --demo        # run the SSH demo with synthetic data and exit
"""

import time
import argparse

from file_monitor  import run_file_check
from logger        import log_event
from alert         import send_alert
from ssh_detector  import parse_log_line, BruteForceDetector, LOG_FILE as AUTH_LOG, run_demo

# ─── Configuration ────────────────────────────────────────────────────────────

SCAN_INTERVAL = 60   # seconds between detection cycles


# ─── SSH Detection ────────────────────────────────────────────────────────────

def run_ssh_scan() -> list[str]:
    """
    Scan AUTH_LOG for brute-force patterns.

    Uses the BruteForceDetector's _pending_alerts list (populated inside
    _fire_alert) so alerts are only raised when the threshold is actually met
    within the sliding time window — not just whenever an IP has >= N entries
    in total.

    Returns a list of alert message strings.
    """
    detector = BruteForceDetector()

    try:
        with open(AUTH_LOG, "r", errors="ignore") as fh:
            for line in fh:
                event = parse_log_line(line)
                if event:
                    detector.process_event(event)
    except FileNotFoundError:
        print(f"[SSH] Log file not found: {AUTH_LOG}  (skipping SSH scan)")
        return []
    except Exception as exc:
        print(f"[ERROR] SSH scan failed: {exc}")
        return []

    # Collect alerts that were fired during processing
    alerts = detector.pop_alerts()

    # Write a HIDS log entry for every alert
    for alert_msg in alerts:
        # Extract the IP from the message for the source field
        parts  = alert_msg.split(":")
        source = parts[1].strip().split(" ")[0] if len(parts) > 1 else "unknown"
        log_event(
            "SSH_BRUTE_FORCE",
            "High",
            source,
            "Multiple failed login attempts detected",
        )

    return alerts


# ─── Single Detection Cycle ───────────────────────────────────────────────────

def run_cycle() -> int:
    """
    Run one full detection cycle (file check + SSH scan).
    Sends alerts for every finding and returns the total alert count.
    """
    print("\n[+] Running HIDS checks...")

    file_alerts = run_file_check()
    ssh_alerts  = run_ssh_scan()
    all_alerts  = file_alerts + ssh_alerts

    # Log every file alert
    for alert in file_alerts:
        a = alert.lower()
        if "modified" in a:
            etype, sev = "FILE_MODIFIED", "High"
        elif "deleted" in a:
            etype, sev = "FILE_DELETED",  "High"
        else:
            etype, sev = "FILE_ADDED",    "Medium"
        source = alert.split(":")[-1].strip().split(" ")[0] if ":" in alert else "unknown"
        log_event(etype, sev, source, alert)

    if all_alerts:
        print(f"[!] {len(all_alerts)} alert(s) found")
        for alert in all_alerts:
            send_alert(alert)
    else:
        print("[+] System clean")

    return len(all_alerts)


# ─── Entry Point ──────────────────────────────────────────────────────────────

def main() -> None:
    parser = argparse.ArgumentParser(description="HIDS — Host-Based Intrusion Detection System")
    group  = parser.add_mutually_exclusive_group()
    group.add_argument("--once", action="store_true",
                       help="Run a single detection cycle and exit")
    group.add_argument("--demo", action="store_true",
                       help="Run the SSH brute-force demo with synthetic data and exit")
    args = parser.parse_args()

    print("=" * 65)
    print("  HIDS Monitoring Started")
    print("=" * 65)
    log_event("SYSTEM", "INFO", "hids.py", "Monitoring started")

    try:
        if args.demo:
            # Run SSH demo only — no real log file needed
            detector = BruteForceDetector()
            run_demo(detector)
            alerts = detector.pop_alerts()
            for msg in alerts:
                send_alert(msg)
            log_event("SYSTEM", "INFO", "hids.py", "Demo completed")
            return

        if args.once:
            count = run_cycle()
            print(f"[+] Cycle done. Alerts: {count}")
            log_event("SYSTEM", "INFO", "hids.py", f"Single cycle completed. Alerts: {count}")
            return

        # Continuous monitoring loop
        while True:
            count = run_cycle()
            print(f"[+] Cycle done. Alerts: {count}")
            print(f"[+] Sleeping for {SCAN_INTERVAL} seconds…\n")
            time.sleep(SCAN_INTERVAL)

    except KeyboardInterrupt:
        print("\n[!] HIDS stopped.")
        log_event("SYSTEM", "INFO", "hids.py", "Monitoring stopped")


if __name__ == "__main__":
    main()
