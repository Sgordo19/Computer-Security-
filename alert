#!/usr/bin/env python3
"""
alerter.py - Desktop alerting system for IslandPay HIDS

Uses Linux desktop notifications via notify-send.
Falls back to terminal print if desktop notification is unavailable.
"""

import subprocess
from datetime import datetime

ALERT_LOG = "alerts.log"


def send_desktop_notification(title, message):
    """Send a desktop notification using notify-send."""
    try:
        subprocess.run(
            ["notify-send", "-u", "critical", "-t", "10000", title, message],
            check=True,
            capture_output=True
        )
        print(f"[ALERT] Desktop notification sent: {title}")
        return True
    except (subprocess.CalledProcessError, FileNotFoundError):
        print(f"[ALERT] Desktop notification unavailable. {title} - {message}")
        return False


def log_alert(message):
    """Log alert messages to alerts.log."""
    timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")

    try:
        with open(ALERT_LOG, "a") as file:
            file.write(f"[{timestamp}] ALERT: {message}\n")
    except Exception as e:
        print(f"[ERROR] Failed to write alert log: {e}")


def send_alert(message):
    """Send desktop notification and record alert."""
    if not message:
        return

    upper_message = message.upper()

    if "SSH BRUTE FORCE" in upper_message:
        title = "HIDS Alert - SSH Attack Detected"
    elif "FILE DELETED" in upper_message:
        title = "HIDS Alert - File Deleted"
    elif "FILE MODIFIED" in upper_message:
        title = "HIDS Alert - File Modified"
    elif "NEW FILE" in upper_message:
        title = "HIDS Alert - New File Detected"
    else:
        title = "HIDS Security Alert"

    send_desktop_notification(title, message)
    log_alert(message)
