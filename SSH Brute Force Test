    "Mar 23 10:05:00 server sshd[1011]: Failed password for root from 172.16.0.8 port 22 ssh2",
]


def run_demo(detector: BruteForceDetector):
    """Feed synthetic log lines to demonstrate detection logic."""
    print("[*] Running built-in demo (synthetic log lines)\n")
    for line in DEMO_LINES:
        event = parse_log_line(line, year=2026)
        if event:
            detector.process_event(event)
    print("\n[*] Demo complete.")


# ─── CLI Entry Point ──────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(
        description="SSH Brute Force Detector — monitors auth.log for attack patterns"
    )
    group = parser.add_mutually_exclusive_group()
    group.add_argument(
        "--analyze", metavar="LOG_FILE",
        help="Batch-scan an existing log file (default: /var/log/auth.log)"
    )
    group.add_argument(
        "--tail", metavar="LOG_FILE",
        help="Live-tail a log file and detect in real time"
    )
    group.add_argument(
        "--demo", action="store_true",
        help="Run with built-in synthetic log data (no real log file needed)"
    )
    parser.add_argument(
        "--threshold", type=int, default=ALERT_THRESHOLD,
        help=f"Failed attempts to trigger alert (default: {ALERT_THRESHOLD})"
    )
    parser.add_argument(
        "--window", type=int, default=TIME_WINDOW_SEC,
        help=f"Time window in seconds (default: {TIME_WINDOW_SEC})"
    )

    args = parser.parse_args()

    detector = BruteForceDetector(threshold=args.threshold, window_sec=args.window)

    print("=" * 65)
    print("  SSH Brute Force Detector")
    print(f"  Alert if ≥ {args.threshold} failures from same IP within {args.window}s")
    print("=" * 65 + "\n")

    if args.demo:
        run_demo(detector)
    elif args.tail:
        tail_file(args.tail, detector)
    elif args.analyze:
        analyze_file(args.analyze, detector)
    else:
        # default: analyze the standard auth.log
        analyze_file(LOG_FILE, detector)


if __name__ == "__main__":
    main()
