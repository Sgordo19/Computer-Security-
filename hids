#!/usr/bin/env python3
"""
hids.py - Main control script for IslandPay Host-Based Intrusion Detection System

This script:
- runs file integrity checks
- runs SSH brute-force detection
- writes centralized logs
- sends desktop alerts
"""

import time
from file_monitor import run_file_check
from ssh_detector import run_ssh_check
from alert import send_alert
from logger import log_event

CHECK_INTERVAL = 60  # seconds


def main():
    print("[*] IslandPay HIDS Starting...")
    log_event("SYSTEM_START", "Low", "hids.py", "IslandPay HIDS started successfully")

    while True:
        print("\n[*] Running file integrity check...")
        file_alerts = run_file_check()

        print("[*] Running SSH brute-force check...")
        ssh_alerts = run_ssh_check()

        all_alerts = file_alerts + ssh_alerts

        for alert in all_alerts:
            send_alert(alert)

        print(f"[*] Scan complete. {len(all_alerts)} alert(s) generated.")
        print(f"[*] Sleeping for {CHECK_INTERVAL} seconds...\n")
        time.sleep(CHECK_INTERVAL)


if __name__ == "__main__":
    main()
