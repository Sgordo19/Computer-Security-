import os
import hashlib
import json


# Change this to "/var/www" if needed
folder_to_watch = "/etc" 
baseline_path = "data.json"

#Create a place to store current file info
current_files = {}

# Walk through the folder and get hashes
for root, dirs, files in os.walk(folder_to_watch):
    for name in files:
        full_path = os.path.join(root, name)
        
        try:
            # Open file and get hash
            file_data = open(full_path, "rb").read()
            file_hash = hashlib.sha256(file_data).hexdigest()
            current_files[full_path] = file_hash
        except:
            continue

# Check if we have a baseline yet
 if os.path.exists(baseline_path) == False:
    # Save the current state as the baseline
    print("No baseline found. Saving current files...")
    f = open(baseline_path, "w")
    json.dump(current_files, f)
    f.close()
    print("Done!")
else:
    # Load the old baseline to compare
    f = open(baseline_path, "r")
    old_files = json.load(f)
    f.close()

    # Look for changes
    print("Checking for changes...")
    
    # Check for Modified or New files
    for path in current_files:
        if path not in old_files:
            print("NEW FILE FOUND: " + path)
        elif current_files[path] != old_files[path]:
            print("FILE WAS MODIFIED: " + path)

    # Check for Deleted files
    for path in old_files:
        if path not in current_files:
            print("FILE WAS DELETED: " + path)
