#!/usr/bin/env python3
"""
logger.py - Centralized incident logging for IslandPay HIDS

All security events are written to hids.log with:
- timestamp
- event type
- severity
- source
- description
"""

from datetime import datetime

LOG_FILE = "hids.log"


def log_event(event_type, severity, source, description):
    """
    Write one structured security event to hids.log.

    Format:
    [timestamp] | event_type | severity | source | description
    """
    timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")

    log_line = (
        f"[{timestamp}] | "
        f"{event_type:<20} | "
        f"{severity:<6} | "
        f"{source:<45} | "
        f"{description}\n"
    )

    try:
        with open(LOG_FILE, "a") as file:
            file.write(log_line)
        print(f"[LOG] {log_line.strip()}")
    except Exception as e:
        print(f"[ERROR] Failed to write to {LOG_FILE}: {e}")
